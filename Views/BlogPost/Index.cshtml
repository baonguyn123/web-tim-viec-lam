@model List<web_jobs.Models.BlogPost>

@{
    ViewData["Title"] = "Danh sách bài viết";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    .card-custom {
        border-radius: 12px;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .table-hover tbody tr:hover {
        background-color: #f0f8ff;
        cursor: pointer;
        transition: background-color 0.2s ease-in-out;
    }

    .btn-add {
        border-radius: 8px;
        font-weight: 500;
        padding: 8px 14px;
    }

    .table th {
        background-color: #f8f9fa;
        font-weight: 600;
    }

    .btn-fixed-left, .btn-fixed-right {
        position: fixed;
        top: 24%;
        transform: translateY(-50%);
        z-index: 999;
        pointer-events: auto;
    }

    .btn-fixed-left {
        left: 20px;
    }

    .btn-fixed-right {
        right: 20px;
    }

    .btn-page-nav {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        font-size: 20px;
        padding: 0;
    }
</style>

<div class="container my-4">
    <div class="card card-custom">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">
                <i class="fa-solid fa-newspaper text-primary"></i> Danh sách bài viết
            </h4>
            <a asp-action="Add" class="btn btn-primary btn-add">
                <i class="fa fa-plus"></i> Thêm bài viết
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-bordered table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>Tiêu đề</th>
                        <th style="width: 150px;">Ngày đăng</th>
                        <th style="width: 120px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr onclick="location.href='@Url.Action("Detail", "BlogPost", new { id = item.ID })'">
                            <td>@item.Title</td>
                            <td>@item.PostedDate.ToString("dd/MM/yyyy")</td>
                            <td>
                                <a asp-action="Update" asp-route-id="@item.ID" class="btn btn-sm btn-warning">
                                    <i class="fa fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ID" class="btn btn-sm btn-danger"
                                   onclick="return confirm('Bạn có chắc muốn xóa?')">
                                    <i class="fa fa-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <i>Không có bài viết nào</i>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@{
    int startPage = Math.Max(2, ViewBag.CurrentPage - 2);
    int endPage = Math.Min(ViewBag.TotalPages - 1, ViewBag.CurrentPage + 2);

    bool showStartEllipsis = startPage > 2;
    bool showEndEllipsis = endPage < ViewBag.TotalPages - 1;
}

@if (ViewBag.TotalPages > 1)
{
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="1">1</a>
            </li>
            @if (showStartEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }
            @if (showEndEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }
            @if (ViewBag.TotalPages > 1)
            {
                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@ViewBag.TotalPages">@ViewBag.TotalPages</a>
                </li>
            }
        </ul>
    </nav>
}
@if (ViewBag.TotalPages > 1)
{
    <form method="get" asp-action="Index" class="btn-fixed-left">
        <input type="hidden" name="page" value="@(ViewBag.CurrentPage - 1)" />
        <button type="submit" class="btn btn-primary btn-page-nav" @(ViewBag.CurrentPage == 1 ? "disabled" : "")>←</button>
    </form>
    <form method="get" asp-action="Index" class="btn-fixed-right">
        <input type="hidden" name="page" value="@(ViewBag.CurrentPage + 1)" />
        <button type="submit" class="btn btn-primary btn-page-nav" @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")>→</button>
    </form>
}
