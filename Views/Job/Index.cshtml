@model IEnumerable<web_jobs.Models.Job>

@{
    ViewData["Title"] = "Danh sách tin tuyển dụng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Tiêu đề */
    .page-title {
        margin: 30px 0 25px;
        text-align: center;
        font-size: 40px;
        font-weight: 800;
        color: #2c3e50;
        letter-spacing: 1px;
    }

    /* Nút đăng tin */
    .btn-primary-add {
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        border: none;
        padding: 10px 18px;
        border-radius: 8px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-primary-add:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 15px rgba(79, 172, 254, 0.4);
        }

    /* Nút lọc */
    .btn-filter-group .btn {
        margin: 5px;
        border-radius: 20px;
        padding: 8px 15px;
        font-weight: 500;
        transition: 0.3s;
    }

        .btn-filter-group .btn:hover {
            transform: translateY(-1px);
        }

    /* Bảng */
    .table {
        border-radius: 12px;
        overflow: hidden;
        background: white;
    }

    thead {
        background: linear-gradient(135deg, #6a11cb, #2575fc);
        color: white;
    }

        thead th {
            padding: 14px;
            font-weight: 600;
            font-size: 15px;
            letter-spacing: 0.5px;
        }

    tbody tr {
        transition: all 0.2s ease-in-out;
    }

        tbody tr:hover {
            background-color: #f9fbff !important;
            transform: scale(1.01);
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

    /* Văn bản bị giới hạn dòng */
    .clamp-lines {
        display: -webkit-box;
        -webkit-line-clamp: 1;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    table th,
    table td {
        vertical-align: middle !important;
        text-align: center;
    }

    /* Badge trạng thái */
    .badge {
        font-size: 14px;
        padding: 6px 10px;
        border-radius: 8px;
    }
    /* Hover row */
    .clickable-row {
        cursor: pointer;
        transition: background-color 0.2s ease-in-out, transform 0.1s;
    }

        .clickable-row:hover {
            background-color: #f1f7ff;
            transform: scale(1.01);
        }

    .btn-fixed-left, .btn-fixed-right {
        position: fixed;
        top: 45%;
        transform: translateY(-50%);
        z-index: 999;
        pointer-events: auto;
    }

    .btn-fixed-left {
        left: 20px;
    }

    .btn-fixed-right {
        right: 20px;
    }

    .btn-page-nav {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        font-size: 20px;
        padding: 0;
    }

    .pagination {
        margin-top: 20px;
    }
</style>

<h2 class="page-title">📄 Danh sách tin tuyển dụng</h2>

<div class="text-center mb-3">
    <a asp-action="Add" class="btn btn-primary-add">
        ➕ Đăng tin tuyển dụng mới
    </a>
</div>

<div class="btn-filter-group text-center mb-4">
    <a asp-action="Index" asp-route-filter="approved" class="btn @(ViewBag.Filter == "approved" ? "btn-success" : "btn-outline-success")">
        🟢 Đã duyệt (@ViewBag.ApprovedCount)
    </a>
    <a asp-action="Index" asp-route-filter="pending" class="btn @(ViewBag.Filter == "pending" ? "btn-warning" : "btn-outline-warning")">
        🟡 Đang chờ (@ViewBag.PendingCount)
    </a>
    <a asp-action="Index" asp-route-filter="rejected" class="btn @(ViewBag.Filter == "rejected" ? "btn-danger" : "btn-outline-danger")">
        🔴 Bị từ chối (@ViewBag.RejectedCount)
    </a>
    <a asp-action="Index" asp-route-filter="expired" class="btn @(ViewBag.Filter == "expired" ? "btn-dark" : "btn-outline-dark")">
        ⏰ Hết hạn (@ViewBag.ExpiredCount)
    </a>
    <a asp-action="Index" class="btn @(string.IsNullOrEmpty(ViewBag.Filter) ? "btn-primary" : "btn-outline-primary")">
        📋 Tất cả (@(ViewBag.ApprovedCount + ViewBag.PendingCount + ViewBag.RejectedCount + ViewBag.ExpiredCountz))
    </a>
</div>

<div class="table-responsive shadow-sm">
    <table class="table table-bordered table-hover align-middle mb-0">
        <thead>
            <tr>
                <th>Tiêu đề</th>
                <th>Miêu tả</th>
                <th>Yêu cầu</th>
                <th>Lương</th>
                <th>Địa điểm</th>
                <th>Hạn chót</th>
                <th>Ngành</th>
                <th>Loại</th>
                <th>Trạng thái</th>
                <th>Ứng viên</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="10" class="text-center text-muted py-4">Không có việc làm nào.</td>
                </tr>
            }
            else
            {
                @foreach (var job in Model)
                {
                    var statusText = "";
                    var badgeClass = "";

                    switch (job.Status?.ToLower())
                    {
                        case "approved":
                            statusText = "🟢 Đã duyệt";
                            badgeClass = "badge bg-success";
                            break;
                        case "pending":
                            statusText = "🟡 Đang chờ";
                            badgeClass = "badge bg-warning text-dark";
                            break;
                        case "rejected":
                            statusText = "🔴 Bị từ chối";
                            badgeClass = "badge bg-danger";
                            break;
                        default:
                            statusText = "❔ Không xác định";
                            badgeClass = "badge bg-secondary";
                            break;
                    }

                    <tr class="clickable-row" onclick="location.href='@Url.Action("Detail", "Job", new { id = job.Id })'">
                        <td>@job.JobTitle</td>
                        <td><div class="clamp-lines">@job.JobDescription</div></td>
                        <td><div class="clamp-lines">@job.Requirements</div></td>
                        <td>@job.Salary</td>
                        <td>@job.Locate</td>
                        <td>@job.ApplicationDeadline?.ToString("dd/MM/yyyy")</td>
                        <td>@job.Category?.Name</td>
                        <td>@job.JobType?.JobType_Name</td>
                        <td><span class="@badgeClass">@statusText</span></td>
                        <td>@(job.Applications?.Count ?? 0)</td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
@{
    int currentPage = (int)ViewBag.CurrentPage;
    int totalPages = (int)ViewBag.TotalPages;

    int startPage = Math.Max(2, currentPage - 2);
    int endPage = Math.Min(totalPages - 1, currentPage + 2);

    bool showStartEllipsis = startPage > 2;
    bool showEndEllipsis = endPage < totalPages - 1;
}

@if (totalPages > 1)
{
    <!-- Nút lùi -->
    <form method="get" asp-action="Index" class="btn-fixed-left">
        <input type="hidden" name="page" value="@(currentPage - 1)" />
        <button type="submit" class="btn btn-primary btn-page-nav" @(currentPage == 1 ? "disabled" : "")>←</button>
    </form>

    <!-- Nút tới -->
    <form method="get" asp-action="Index" class="btn-fixed-right">
        <input type="hidden" name="page" value="@(currentPage + 1)" />
        <button type="submit" class="btn btn-primary btn-page-nav" @(currentPage == totalPages ? "disabled" : "")>→</button>
    </form>

    <!-- Thanh phân trang số -->
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center mb-0">
            <!-- Trang đầu tiên luôn hiển thị -->
            <li class="page-item @(currentPage == 1 ? "active" : "")">
                <a class="page-link" asp-action="Index" asp-route-page="1">1</a>
            </li>

            <!-- Hiển thị dấu ... nếu cần -->
            @if (showStartEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }

            <!-- Các trang giữa -->
            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                </li>
            }

            <!-- Hiển thị dấu ... nếu cần -->
            @if (showEndEllipsis)
            {
                <li class="page-item disabled"><span class="page-link">...</span></li>
            }

            <!-- Trang cuối luôn hiển thị (nếu có nhiều hơn 1 trang) -->
            @if (totalPages > 1)
            {
                <li class="page-item @(currentPage == totalPages ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@totalPages">@totalPages</a>
                </li>
            }
        </ul>
    </nav>
}