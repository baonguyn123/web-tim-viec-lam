@using System.Globalization
@model web_jobs.Models.Employer
@{
    ViewData["Title"] = "Đăng ký nhà tuyển dụng";
    Layout = "~/Views/Shared/_Layout.cshtml";
    <link rel="stylesheet" href="~/css/job.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}
<style>
    .register-wrapper {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        align-items: stretch;
        min-height: 80vh;
        padding: 40px 20px;
        animation: fadeIn 1s ease;
    }

    .register-left {
        flex: 1;
        min-width: 300px;
        background: linear-gradient(to bottom right, #007bff, #00c6ff);
        color: white;
        padding: 40px;
        border-radius: 12px 0 0 12px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        text-align: center;
    }

        .register-left h2 {
            font-size: 32px;
            margin-bottom: 20px;
        }

        .register-left p {
            font-size: 18px;
        }

        .register-left img {
            max-width: 200px;
            margin: 0 auto 20px;
        }

    .register-right {
        flex: 1.5;
        min-width: 300px;
        background-color: #fff;
        padding: 40px;
        border-radius: 0 12px 12px 0;
        box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .form-group {
        margin-bottom: 20px;
    }

    .btn {
        width: 100%;
    }

    .register-left, .register-right {
        border-radius: 12px;
    }
</style>

<div class="register-wrapper">
    <!-- Bên trái: ảnh + slogan -->
    <div class="register-left">
 
        <h2>“Hợp tác cùng phát triển – Thu hút nhân tài!”</h2>
        <p>Đăng ký công ty để kết nối với ứng viên phù hợp.</p>
    </div>

    <!-- Bên phải: form đăng ký nhà tuyển dụng -->
    <div class="register-right">
        <h3 class="mb-4">Thông tin đăng ký công ty</h3>

        <form asp-action="Add" asp-controller="Employer" method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label asp-for="CompanyName">Tên công ty</label>
                <input asp-for="CompanyName" class="form-control" />
                <span asp-validation-for="CompanyName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CompanyEmail">Email công ty</label>
                <input asp-for="CompanyEmail" class="form-control" />
                <span asp-validation-for="CompanyEmail" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CompanySize">Quy mô công ty</label>
                <input asp-for="CompanySize" class="form-control" />
                <span asp-validation-for="CompanySize" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="CompanyDescription">Mô tả công ty</label>
                <textarea asp-for="CompanyDescription" class="form-control"></textarea>
                <span asp-validation-for="CompanyDescription" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Logo công ty</label>
                <input type="file" name="logoFile" class="form-control" accept=".jpg,.jpeg,.png" />
                <span class="text-danger">@ViewData.ModelState["LogoFile"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
                <small class="text-muted">Ảnh PNG, JPG, JPEG</small>
            </div>

            <div class="form-group">
                <label>Giấy phép kinh doanh</label>
                <input type="file" name="licenseFile" class="form-control" accept=".pdf,.jpg,.jpeg,.png" />
                <span class="text-danger">@ViewData.ModelState["LicenseFile"]?.Errors.FirstOrDefault()?.ErrorMessage</span>
                <small class="text-muted">Tệp PDF hoặc hình ảnh</small>
            </div>
           <div class="form-group">
    <label>Địa chỉ công ty</label>
    <input type="text" id="address-input" name="CompanyAddress" class="form-control" placeholder="Nhập địa chỉ..." />
</div>
            <div id="map" style="height: 400px; margin-top: 10px;"></div>
            <!-- Hiển thị giá trị tọa độ đã chọn -->
            <div class="mt-2">
                <strong>Vĩ độ (Latitude):</strong> <span id="lat-value">Chưa chọn</span><br />
                <strong>Kinh độ (Longitude):</strong> <span id="lng-value">Chưa chọn</span>
            </div>

            <input type="hidden" id="Latitude" name="Latitude"
                   value="@(Model.Latitude.HasValue ? Model.Latitude.Value.ToString("F6", CultureInfo.InvariantCulture) : "")" />

            <input type="hidden" id="Longitude" name="Longitude"
                   value="@(Model.Longitude.HasValue ? Model.Longitude.Value.ToString("F6", CultureInfo.InvariantCulture) : "")" />

            <button type="submit" class="btn btn-primary mt-2">Lưu thông tin</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        let map = L.map('map').setView([21.0278, 105.8342], 13); // Hà Nội mặc định

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        let marker;

        // Hàm cập nhật tọa độ và hiển thị
        function updateLocation(lat, lng) {
            if (marker) {
                marker.setLatLng([lat, lng]).bindPopup(`Vị trí đã chọn:<br>Lat: ${lat.toFixed(6)}<br>Lng: ${lng.toFixed(6)}`).openPopup();
            } else {
                marker = L.marker([lat, lng]).addTo(map)
                    .bindPopup(`Vị trí đã chọn:<br>Lat: ${lat.toFixed(6)}<br>Lng: ${lng.toFixed(6)}`).openPopup();
            }
            document.getElementById("Latitude").value = lat.toFixed(6);
        document.getElementById("Longitude").value = lng.toFixed(6);
            document.getElementById("lat-value").innerText = lat.toFixed(6);
            document.getElementById("lng-value").innerText = lng.toFixed(6);
        }

        // Click bản đồ
        map.on('click', function (e) {
            let lat = e.latlng.lat;
            let lng = e.latlng.lng;
            updateLocation(lat, lng);
        });

        // Nhập địa chỉ
        document.getElementById("address-input").addEventListener("change", function () {
            const query = this.value;
            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`)
                .then(response => response.json())
                .then(data => {
                    if (data && data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lon = parseFloat(data[0].lon);

                        map.setView([lat, lon], 16);
                        updateLocation(lat, lon);
                    } else {
                        alert("Không tìm thấy địa chỉ. Vui lòng thử lại.");
                    }
                })
                .catch(() => alert("Lỗi khi tìm địa chỉ."));
        });
    </script>

}
