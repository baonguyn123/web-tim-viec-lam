@model web_jobs.Models.Employer

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

<style>
    .status-card {
        max-width: 600px;
        margin: 40px auto;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
        background: #fff;
        padding: 30px 40px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: #2c3e50;
    }

        .status-card h3 {
            font-weight: 700;
            font-size: 1.9rem;
            margin-bottom: 30px;
            color: #34495e;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .status-card p {
            font-size: 1.1rem;
            margin-bottom: 18px;
            line-height: 1.5;
        }

        .status-card strong {
            color: #34495e;
            font-weight: 600;
        }

    .badge {
        font-size: 1rem;
        padding: 8px 16px;
        border-radius: 25px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-weight: 600;
    }

    .alert-info {
        background-color: #e7f3fe;
        border-color: #b3d4fc;
        color: #3178c6;
        font-size: 1rem;
        border-radius: 12px;
        padding: 15px 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-top: 25px;
        box-shadow: 0 4px 15px rgba(49, 120, 198, 0.15);
    }

    /* Badge màu sắc */
    .bg-success {
        background: #2ecc71;
        color: white;
    }

    .bg-warning {
        background: #f1c40f;
        color: #222;
    }

    .bg-danger {
        background: #e74c3c;
        color: white;
    }

    .bg-secondary {
        background: #95a5a6;
        color: white;
    }

    .bg-info {
        background: #3498db;
        color: white;
    }

</style>

<div class="status-card">
    <h3>
        <i class="fas fa-building text-primary"></i> Trạng thái công ty của bạn
    </h3>

    <p><strong>Tên công ty:</strong> @Model.CompanyName</p>
    <p><strong>Email công ty:</strong> @Model.CompanyEmail</p>

    <p>
        <strong>Trạng thái duyệt:</strong><br />
        @if (string.IsNullOrEmpty(Model.Status))
        {
            <span class="badge bg-secondary">Chưa có trạng thái</span>
        }
        else if (Model.Status.ToLower() == "approved")
        {
            <span class="badge bg-success">
                Đã được duyệt <i class="fas fa-check-circle"></i>
            </span>
        }
        else if (Model.Status.ToLower() == "pending")
        {
            <span class="badge bg-warning">
                Đang chờ duyệt <i class="fas fa-hourglass-half"></i>
            </span>
        }
        else if (Model.Status.ToLower() == "rejected")
        {
            <span class="badge bg-danger">
                Bị từ chối <i class="fas fa-times-circle"></i>
            </span>
        }
        else
        {
            <span class="badge bg-info">@Model.Status</span>
        }
    </p>

    @if (Model.Status?.ToLower() != "approved")
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i>
            Bạn chưa được duyệt. Vui lòng chờ admin duyệt hoặc cập nhật lại thông tin công ty.
        </div>
    }
</div>
