@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}
<style>
    

    .tab-box {
        display: flex;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .tab-content.active {
        display: block;
    }

    .tab-content {
        display: none;
    }

    .tab-btn {
        padding: 10px 20px;
        border: none;
        background-color: transparent;
        font-weight: bold;
        font-size: 16px;
        cursor: pointer;
        color: #555;
        transition: color 0.3s, border-bottom 0.3s;
    }

    .tab-btn.active {
        color: #007bff;
        border-bottom: 2px solid #007bff;
    }

    .tab-content {
        display: none;
    }

    .tab-content.active {
        display: block;
        animation: fadeIn 0.3s ease-in-out;
    }

   

    .card {
        border-radius: 16px;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
    }

    .form-floating label {
        padding-left: 12px;
    }

    .btn-google {
        background-color: white;
        color: #555;
        border: 1px solid #ddd;
        font-weight: 500;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 8px;
        border-radius: 4px;
        text-decoration: none;
        margin-bottom:16px;
    }

        .btn-google img {
            height: 18px;
            margin-right: 8px;
        }

        .btn-google:hover {
            background-color: #f7f7f7;
        }
</style>

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow p-4" style="max-width: 450px; width: 100%; background-color: rgba(255,255,255,0.96);">
        <div class="text-center mb-3">
            <img src="~/images/job3.jpg" alt="Logo HUTECH" style="height: 60px;" />
            <h4 class="mt-2">Tìm việc làm</h4>
            <p class="text-muted">Cổng thông tin tài khoản</p>
        </div>

        <!-- Tabs -->
        <div class="tab-box">
            <button class="tab-btn active" onclick="showTab(0)">Đăng nhập</button>
            <button class="tab-btn" onclick="showTab(1)">Đăng ký</button>
        </div>

        <!-- Login Form -->
        <div id="login" class="tab-content active">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="form-label">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                    <label asp-for="Input.Password" class="form-label">Mật khẩu</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>
                <div class="checkbox mb-3">
                    <label asp-for="Input.RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        @Html.DisplayNameFor(m => m.Input.RememberMe)
                    </label>
                </div>
                <div class="mt-3 text-center">
                    <a class="btn btn-google w-100" href="/ExternalLogin/Google">
                        <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google logo">
                        Đăng nhập bằng Google
                    </a>
                </div>
                <div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Đăng nhập</button>
                </div>
                <div class="mt-3 text-center">
                    <p><a id="forgot-password" asp-page="./ForgotPassword">Quên mật khẩu?</a></p>
                    <p><a id="resend-confirmation" asp-page="./ResendEmailConfirmation">Gửi lại email xác nhận</a></p>
                </div>
            </form>
        </div>

        <!-- Register Redirect -->
        <div id="register" class="tab-content">
            <div class="text-center">
                <p>Bạn chưa có tài khoản?</p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-primary">Chuyển đến trang đăng ký</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showTab(index) {
            const tabs = document.querySelectorAll(".tab-btn");
            const contents = document.querySelectorAll(".tab-content");
			tabs.forEach((tab, i) => {
				tab.classList.toggle("active", i === index);
				contents[i].classList.toggle("active", i === index);
			});
        }
    </script>
}